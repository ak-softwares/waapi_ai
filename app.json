{
  "expo": {
    "name": "WA-API AI",
    "slug": "waapi_ai",
    "version": "1.1.5",
    "orientation": "portrait",
    "icon": "./assets/logos/icon.png",
    "scheme": "waapiapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.waapi.ai",
      "supportsTablet": true
    },
    "splash": {
      "image": "./assets/logos/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F9D58"
    },
    "android": {
      "package": "com.waapi.ai",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/logos/icon.png",
        "backgroundImage": "./assets/logos/icon.png",
        "monochromeImage": "./assets/logos/icon.png"
      },
      "notification": {
        "icon": "./assets/logos/notification-icon.png",
        "color": "#25D366"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/logos/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/logos/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/logos/notification-icon.png",
          "color": "#25D366"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3622e8ba-256f-4981-aa76-2612cde2934a"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    }
  }
}
