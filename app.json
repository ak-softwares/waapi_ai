{
  "expo": {
    "name": "WA-API AI",
    "slug": "waapi_ai",
    "version": "1.3.1",
    "orientation": "portrait",
    "owner": "waapi.me",
    "icon": "./assets/logos/adaptive-icon.png",
    "scheme": "waapiapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.waapi.ai",
      "supportsTablet": true,
      "icon": {
        "light": "./assets/logos/ios-light.png",
        "dark": "./assets/logos/ios-dark.png",
        "tinted": "./assets/logos/ios-tinted.png"
      }
    },
    "splash": {
      "image": "./assets/logos/splash-icon-light.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F9D58"
    },
    "android": {
      "package": "com.waapi.ai",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logos/adaptive-icon.png",
        "monochromeImage": "./assets/logos/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "notification": {
        "icon": "./assets/logos/notification-icon.png",
        "color": "#25D366"
      },
      "softwareKeyboardLayoutMode": "pan",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/logos/adaptive-icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/logos/splash-icon-light.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF",
          "dark": {
            "image": "./assets/logos/splash-icon-dark.png",
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/logos/notification-icon.png",
          "color": "#25D366"
        }
      ],
      "expo-web-browser",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3911355756516980~1239342935",
          "iosAppId": "ca-app-pub-3911355756516980~1239342935"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "googleWebClientId": "424327448768-larhq3ujtbcfqfkvtafpdvkdk1f15jte.apps.googleusercontent.com",
      "googleAndroidClientId": "424327448768-0o8943v29kg0rd94ak716u33bv030tp1.apps.googleusercontent.com",
      "googleIosClientId": "424327448768-vm5h13edei04htscnf1cgrjgdo92s3id.apps.googleusercontent.com",
      "router": {},
      "eas": {
        "projectId": "3622e8ba-256f-4981-aa76-2612cde2934a"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    }
  }
}
